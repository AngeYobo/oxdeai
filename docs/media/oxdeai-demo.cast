[22.36624, "o", "   decision 1: \u001b[1;32mALLOW\u001b[0m\r\n   decision 2: \u001b[1;32mALLOW\u001b[0m\r\n   decision 3: \u001b[1;31mDENY\u001b[0m\r\n   verifyEnvelope() => \u001b[1;32mok\u001b[0m\r\n\r\n\u001b[1;32mвң“ Verification passed.\u001b[0m\r\n\r\n  \u001b[1;97mWhat just happened:\u001b[0m\r\n  \u001b[36mв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\u001b[0m\r\n  \u001b[36mв”Ӯ\u001b[0m \u001b[1;36mPDP\u001b[0m  OxDeAI evaluated each intent before any tool ran.          \u001b[36mв”Ӯ\u001b[0m\r\n  \u001b[36mв”Ӯ\u001b[0m      Call 3 was \u001b[1;31mdenied\u001b[0m at the boundary вҖ” tool never touched.    \u001b[36mв”Ӯ\u001b[0m\r\n  \u001b[36mв”Ӯ\u001b[0m                                                                 \u001b[36mв”Ӯ\u001b[0m\r\n  \u001b[36mв”Ӯ\u001b[0m \u001b[1;36mPEP\u001b[0m  Tool only executed after Authorization was confirmed.      \u001b[36mв”Ӯ\u001b[0m\r\n  \u001b[36mв”Ӯ\u001b[0m      No Authorization = no execution, even on \u001b[1;32mALLOW\u001b[0m.            \u001b[36mв”Ӯ\u001b[0m\r\n  \u001b[36mв”Ӯ\u001b[0m                                                                 \u001b[36mв”Ӯ\u001b"]
[22.366264, "o", "[0m\r\n  \u001b[36mв”Ӯ\u001b[0m \u001b[1;36mAUDIT\u001b[0m  8 hash-chained events record the full execution history. \u001b[36mв”Ӯ\u001b[0m\r\n  \u001b[36mв”Ӯ\u001b[0m                                                                 \u001b[36mв”Ӯ\u001b[0m\r\n"]

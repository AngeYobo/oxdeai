{
  "name": "@oxdeai/core",
  "version": "1.6.1",
  "description": "Deterministic execution-time authorization engine for AI agents. Evaluates proposed actions against intent, state, and policy before execution and emits cryptographically verifiable authorization artifacts.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "types": "./dist/adapters/index.d.ts"
    },
    "./verification": {
      "import": "./dist/verification/index.js",
      "types": "./dist/verification/index.d.ts"
    },
    "./snapshot": {
      "import": "./dist/snapshot/index.js",
      "types": "./dist/snapshot/index.d.ts"
    },
    "./crypto": {
      "import": "./dist/crypto/hashes.js",
      "types": "./dist/crypto/hashes.d.ts"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AngeYobo/oxdeai.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/AngeYobo/oxdeai",
  "bugs": {
    "url": "https://github.com/AngeYobo/oxdeai/issues"
  },
  "keywords": [
    "ai-agents",
    "agent-security",
    "agent-authorization",
    "execution-time-authorization",
    "pre-execution-authorization",
    "policy-engine",
    "policy-enforcement-point",
    "execution-authorization",
    "authorization-artifact",
    "authorization-protocol",
    "verification-protocol",
    "deterministic-verification",
    "fail-closed",
    "autonomous-systems",
    "agent-safety",
    "deterministic"
  ],
  "files": [
    "dist",
    "schemas",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:node": "node --test \"dist/test/*.test.js\"",
    "test": "pnpm build && pnpm test:node",
    "api:report": "pnpm build && api-extractor run --local --config api-extractor.json",
    "api:check": "pnpm build && api-extractor run --config api-extractor.json",
    "schema:validate": "node scripts/schema-validate.mjs",
    "api:fingerprint": "pnpm build && ../../scripts/api-fingerprint.sh",
    "api:fingerprint:check": "pnpm build && ../../scripts/check-api-fingerprint.sh"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.57.6"
  }
}

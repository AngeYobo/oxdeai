{
  "version": "1.3.0",
  "description": "Conformance vectors for verifyDelegation() - isolated delegation artifact checks without chain resolution.",
  "vectors": [
    {
      "id": "delegation-verify-001",
      "description": "valid delegation - no signature check, correct fields, not expired",
      "input": {
        "delegation": {
          "delegation_id": "d1d1d1d1-0000-0000-0000-000000000001",
          "issuer": "parent-agent",
          "audience": "child-agent",
          "parent_auth_hash": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
          "delegator": "parent-agent",
          "delegatee": "child-agent",
          "scope": {},
          "policy_id": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
          "issued_at": 1000000,
          "expiry": 1002000,
          "alg": "Ed25519",
          "kid": "2026-01",
          "signature": "placeholder"
        },
        "opts": { "now": 1001000 }
      },
      "expected": { "status": "ok", "violations": [] }
    },
    {
      "id": "delegation-verify-002",
      "description": "expired delegation - expiry < now",
      "input": {
        "delegation": {
          "delegation_id": "d1d1d1d1-0000-0000-0000-000000000002",
          "issuer": "parent-agent",
          "audience": "child-agent",
          "parent_auth_hash": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
          "delegator": "parent-agent",
          "delegatee": "child-agent",
          "scope": {},
          "policy_id": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
          "issued_at": 1000000,
          "expiry": 1000999,
          "alg": "Ed25519",
          "kid": "2026-01",
          "signature": "placeholder"
        },
        "opts": { "now": 1001000 }
      },
      "expected": {
        "status": "invalid",
        "violations": [{ "code": "DELEGATION_EXPIRED", "message": "delegation has expired" }]
      }
    },
    {
      "id": "delegation-verify-003",
      "description": "expiry === now - boundary: expired (now >= expiry)",
      "input": {
        "delegation": {
          "delegation_id": "d1d1d1d1-0000-0000-0000-000000000003",
          "issuer": "parent-agent",
          "audience": "child-agent",
          "parent_auth_hash": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
          "delegator": "parent-agent",
          "delegatee": "child-agent",
          "scope": {},
          "policy_id": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
          "issued_at": 1000000,
          "expiry": 1001000,
          "alg": "Ed25519",
          "kid": "2026-01",
          "signature": "placeholder"
        },
        "opts": { "now": 1001000 }
      },
      "expected": {
        "status": "invalid",
        "violations": [{ "code": "DELEGATION_EXPIRED", "message": "delegation has expired" }]
      }
    },
    {
      "id": "delegation-verify-004",
      "description": "missing required field - delegation_id empty",
      "input": {
        "delegation": {
          "delegation_id": "",
          "issuer": "parent-agent",
          "audience": "child-agent",
          "parent_auth_hash": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
          "delegator": "parent-agent",
          "delegatee": "child-agent",
          "scope": {},
          "policy_id": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
          "issued_at": 1000000,
          "expiry": 1002000,
          "alg": "Ed25519",
          "kid": "2026-01",
          "signature": "placeholder"
        },
        "opts": { "now": 1001000 }
      },
      "expected": {
        "status": "invalid",
        "violations": [{ "code": "DELEGATION_MISSING_FIELD", "message": "delegation_id is required" }]
      }
    },
    {
      "id": "delegation-verify-005",
      "description": "scope.tools violation - child requests tool not in parent scope",
      "input": {
        "delegation": {
          "delegation_id": "d1d1d1d1-0000-0000-0000-000000000005",
          "issuer": "parent-agent",
          "audience": "child-agent",
          "parent_auth_hash": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
          "delegator": "parent-agent",
          "delegatee": "child-agent",
          "scope": { "tools": ["query_db", "provision_gpu"] },
          "policy_id": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
          "issued_at": 1000000,
          "expiry": 1002000,
          "alg": "Ed25519",
          "kid": "2026-01",
          "signature": "placeholder"
        },
        "opts": {
          "now": 1001000,
          "parentScope": { "tools": ["provision_gpu"] }
        }
      },
      "expected": {
        "status": "invalid",
        "violations": [{ "code": "DELEGATION_SCOPE_VIOLATION", "message": "scope.tools contains tools not in parent: query_db" }]
      }
    },
    {
      "id": "delegation-verify-006",
      "description": "scope.max_amount violation - child max_amount exceeds parent",
      "input": {
        "delegation": {
          "delegation_id": "d1d1d1d1-0000-0000-0000-000000000006",
          "issuer": "parent-agent",
          "audience": "child-agent",
          "parent_auth_hash": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
          "delegator": "parent-agent",
          "delegatee": "child-agent",
          "scope": { "max_amount": "500" },
          "policy_id": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
          "issued_at": 1000000,
          "expiry": 1002000,
          "alg": "Ed25519",
          "kid": "2026-01",
          "signature": "placeholder"
        },
        "opts": {
          "now": 1001000,
          "parentScope": { "max_amount": "300" }
        }
      },
      "expected": {
        "status": "invalid",
        "violations": [{ "code": "DELEGATION_SCOPE_VIOLATION", "message": "scope.max_amount 500 exceeds parent max_amount 300" }]
      }
    },
    {
      "id": "delegation-verify-007",
      "description": "delegatee mismatch - expectedDelegatee does not match delegation.delegatee",
      "input": {
        "delegation": {
          "delegation_id": "d1d1d1d1-0000-0000-0000-000000000007",
          "issuer": "parent-agent",
          "audience": "child-agent",
          "parent_auth_hash": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
          "delegator": "parent-agent",
          "delegatee": "child-agent",
          "scope": {},
          "policy_id": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
          "issued_at": 1000000,
          "expiry": 1002000,
          "alg": "Ed25519",
          "kid": "2026-01",
          "signature": "placeholder"
        },
        "opts": {
          "now": 1001000,
          "expectedDelegatee": "other-agent"
        }
      },
      "expected": {
        "status": "invalid",
        "violations": [{ "code": "DELEGATION_AUDIENCE_MISMATCH", "message": "delegatee does not match expectedDelegatee" }]
      }
    },
    {
      "id": "delegation-verify-008",
      "description": "replay - delegation_id already present in consumedDelegationIds",
      "input": {
        "delegation": {
          "delegation_id": "d1d1d1d1-0000-0000-0000-000000000008",
          "issuer": "parent-agent",
          "audience": "child-agent",
          "parent_auth_hash": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
          "delegator": "parent-agent",
          "delegatee": "child-agent",
          "scope": {},
          "policy_id": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
          "issued_at": 1000000,
          "expiry": 1002000,
          "alg": "Ed25519",
          "kid": "2026-01",
          "signature": "placeholder"
        },
        "opts": {
          "now": 1001000,
          "consumedDelegationIds": ["d1d1d1d1-0000-0000-0000-000000000008"]
        }
      },
      "expected": {
        "status": "invalid",
        "violations": [{ "code": "DELEGATION_REPLAY", "message": "delegation_id has already been consumed" }]
      }
    },
    {
      "id": "delegation-verify-009",
      "description": "requireSignatureVerification with no trustedKeySets → DELEGATION_TRUST_MISSING",
      "input": {
        "delegation": {
          "delegation_id": "d1d1d1d1-0000-0000-0000-000000000009",
          "issuer": "parent-agent",
          "audience": "child-agent",
          "parent_auth_hash": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
          "delegator": "parent-agent",
          "delegatee": "child-agent",
          "scope": {},
          "policy_id": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
          "issued_at": 1000000,
          "expiry": 1002000,
          "alg": "Ed25519",
          "kid": "2026-01",
          "signature": "placeholder"
        },
        "opts": {
          "now": 1001000,
          "requireSignatureVerification": true
        }
      },
      "expected": {
        "status": "invalid",
        "violations": [{ "code": "DELEGATION_TRUST_MISSING", "message": "trustedKeySets required for Ed25519 verification" }]
      }
    }
  ]
}

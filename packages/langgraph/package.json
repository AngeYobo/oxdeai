{
  "name": "@oxdeai/langgraph",
  "version": "1.0.1",
  "license": "Apache-2.0",
  "description": "Thin LangGraph adapter for the OxDeAI universal execution guard",
  "keywords": [
    "oxdeai",
    "langgraph",
    "langchain",
    "ai-agents",
    "agent-security",
    "agent-authorization",
    "execution-authorization",
    "execution-guard",
    "deterministic-policy",
    "agent-safety",
    "autonomous-systems",
    "authorization-protocol"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "dependencies": {
    "@oxdeai/core": "workspace:*",
    "@oxdeai/guard": "workspace:*"
  },
  "devDependencies": {
    "@oxdeai/sdk": "workspace:*"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "pnpm build && node --test \"dist/test/adapter.test.js\""
  }

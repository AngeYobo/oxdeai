{
  "name": "@oxdeai/cli",
  "version": "0.2.2",
  "description": "Protocol-focused CLI tooling for OxDeAI artifact build/verify/replay workflows",
  "type": "module",
  "bin": {
    "oxdeai": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@oxdeai/core": "^1.3.0"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.json && node scripts/postbuild.mjs",
    "cli": "node dist/main.js",
    "start": "node dist/main.js",
    "prepack": "pnpm build",
    "test": "pnpm build && node --test \"dist/**/*.test.js\""
  }
}

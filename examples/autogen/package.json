{
  "name": "@oxdeai/example-autogen",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "OxDeAI pre-execution economic boundary demo - AutoGen pattern",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "pnpm build && node dist/run.js",
    "validate": "node ../../scripts/validate-adapters.mjs --one autogen",
    "demo:autogen": "pnpm -C examples/autogen build && node examples/autogen/dist/run.js"
  },
  "dependencies": {
    "@oxdeai/core": "workspace:*",
    "@oxdeai/autogen": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}

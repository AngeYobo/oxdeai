{
  "name": "@oxdeai/example-langgraph",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "OxDeAI pre-execution economic boundary demo - LangGraph pattern",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "pnpm build && node dist/run.js",
    "validate": "node ../../scripts/validate-adapters.mjs --one langgraph",
    "demo:langgraph": "pnpm -C examples/langgraph build && node examples/langgraph/dist/run.js"
  },
  "dependencies": {
    "@langchain/core": "^1.1.41",
    "@langchain/langgraph": "^1.2.9",
    "@oxdeai/core": "workspace:*",
    "@oxdeai/langgraph": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
